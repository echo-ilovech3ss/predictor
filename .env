# Starting virtual balance for paper trading and backtesting
STARTING_CAPITAL=100000.0

# Market timeframe (strictly 1h is supported)
TIMEFRAME=1h

# Risk Management
STOP_LOSS_PCT=2.0
DAILY_LOSS_LIMIT_PCT=5.0
MAX_POSITION_SIZE_PCT=20.0
MAX_TRADES_PER_DAY=3
MIN_CONFIDENCE_FOR_TRADE=0.60

# Transaction Costs (brokerage, slippage, tax on profits)
SLIPPAGE_PCT=0.05
BROKERAGE_PCT=0.03
TAX_ON_PROFIT_PCT=15.0

# Safety flag - must remain true
PAPER_TRADING_ONLY=true
